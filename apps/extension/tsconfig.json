{
  // `.wxt/tsconfig.json` is generated by `wxt prepare`; it wires up the `@/*`
  // aliases and (via its included `.wxt/types/*.d.ts`) the `#imports` module and
  // WebExtension globals. We must therefore include `.wxt` here. Our shared
  // strictness lives in the repo-root base config.
  "extends": ["../../tsconfig.base.json", "./.wxt/tsconfig.json"],
  "include": [
    ".wxt/**/*",
    "entrypoints/**/*",
    "lib/**/*",
    "tests/**/*",
    "vite-env.d.ts",
    "wxt.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", ".output"]
}
