{
  "name": "vibesters-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hide vibecoding tags and mute vibecoding comment threads on lobste.rs / lobsters.dev",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run dev:chrome",
    "dev:chrome": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari",
    "zip": "pnpm run zip:chrome && pnpm run zip:firefox",
    "zip:chrome": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check:types": "wxt prepare && tsc --noEmit",
    "check:lint": "web-ext lint --source-dir .output/firefox-mv2 --no-config-discovery",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}
