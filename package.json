{
  "name": "vibesters",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension that hides vibecoding tags and mutes vibecoding comment threads on lobste.rs",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "pnpm -C apps/extension dev",
    "dev:firefox": "pnpm -C apps/extension dev:firefox",
    "check:types": "pnpm -r run check:types",
    "check:formatting": "prettier --check .",
    "format": "prettier --write .",
    "test:unit": "pnpm -r run test:unit",
    "test:e2e": "pnpm -r run test:e2e",
    "build": "pnpm -r run build",
    "build:safari": "pnpm -r run build:safari",
    "zip": "pnpm -r run zip",
    "regen:icons": "bash scripts/regen-icons.sh",
    "regen:screenshots": "node scripts/screenshots.mjs",
    "postinstall": "pnpm -r --if-present run postinstall"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "prettier": "^3.9.1"
  }
}
